<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vacaciones Robóticas LMAC 2026</title>
<style>
body{font-family:Arial,sans-serif;background:#f4f7fa;margin:0;padding:20px}
.container{max-width:1200px;margin:auto;background:#fff;padding:20px;border-radius:15px}
h1{color:#00a6b2;text-align:center}
.months{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:15px}
.month{border:1px solid #ddd;border-radius:12px;padding:10px}
.weekdays,.days{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.weekdays div{background:#00a6b2;color:#fff;text-align:center;padding:6px;border-radius:4px;font-weight:bold}
.day{padding:8px;text-align:center;border:1px solid #ddd;border-radius:6px;cursor:pointer}
.available{background:#e8f8fa}
.selected{background:#007f8a;color:#fff}
.blocked{background:#e53935;color:#fff;cursor:not-allowed}
.outside{background:#eee;color:#999}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
input,select,textarea{width:100%;padding:10px;box-sizing:border-box}
.resumen{background:#fff6e9;padding:15px;border-radius:10px;margin:15px 0}
button{background:#00a6b2;color:white;border:none;padding:12px 18px;border-radius:8px;cursor:pointer}
.legend{padding:10px;background:#f8f8f8;border-radius:8px;margin-bottom:10px}
@media(max-width:700px){.grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="container">
<h1>🚀 Vacaciones Robóticas Academia LMAC 2026</h1>

<div class="legend">
🟢 Disponible &nbsp; 🔵 Seleccionado &nbsp; 🔴 Domingos/Festivos
</div>

<div class="months" id="months"></div>

<div class="resumen">
<h3>Resumen</h3>
<p>Sesiones: <span id="sesiones">0</span></p>
<p>Total: $<span id="total">0</span></p>
<p><strong>Fechas seleccionadas:</strong></p>
<div id="listaFechas"></div>
</div>

<h2>Datos del estudiante</h2>
<div class="grid">
<input id="estudiante" placeholder="Nombres y apellidos">
<input id="edad" type="number" placeholder="Edad">
<input id="colegio" placeholder="Colegio">
<input id="acudiente" placeholder="Nombre del acudiente">
<input id="cedula" placeholder="Cédula">
<input id="telefono" placeholder="Teléfono">
<input id="email" placeholder="Correo electrónico">
<input id="direccion" placeholder="Dirección">
</div>

<select id="formaPago">
<option>Nequi</option>
<option>Bancolombia</option>
<option>Transferencia</option>
<option>Efectivo</option>
<option>Otro</option>
</select>

<textarea id="observaciones" placeholder="Observaciones"></textarea>

<select id="autorizacion">
<option>Sí</option>
<option>No</option>
</select>

<br><br>
<button onclick="reservar()">Reservar Cupo</button>
</div>

<script>
const URL_SCRIPT="https://script.google.com/macros/s/AKfycbzmQgVZ_GB7XUK0XAZY3Z5ZwgGbp202qSuIx5ge8sALRYq6uP40JMY8eTLhvoPHWiAFTw/exec";
const festivos=["2026-06-29","2026-07-20","2026-08-07"];
const seleccionadas=[];

function crearMes(year,month,nombre){
 const cont=document.createElement("div");
 cont.className="month";
 cont.innerHTML=`<h3>${nombre}</h3>
 <div class="weekdays">
 <div>D</div><div>L</div><div>M</div><div>M</div><div>J</div><div>V</div><div>S</div>
 </div><div class="days"></div>`;

 const days=cont.querySelector(".days");
 const first=new Date(year,month,1).getDay();

 for(let i=0;i<first;i++){
   let e=document.createElement("div");
   e.className="day outside";
   days.appendChild(e);
 }

 const last=new Date(year,month+1,0).getDate();

 for(let d=1;d<=last;d++){
   const dt=new Date(year,month,d);
   const iso=dt.toISOString().split('T')[0];

   const div=document.createElement("div");
   div.innerHTML=d;

   const domingo=dt.getDay()===0;
   const fuera=(iso<"2026-06-16" || iso>"2026-08-14");

   if(domingo || festivos.includes(iso)){
      div.className="day blocked";
   }else if(fuera){
      div.className="day outside";
   }else{
      div.className="day available";
      div.onclick=()=>{
        if(div.classList.contains("selected")){
          div.classList.remove("selected");
          const i=seleccionadas.indexOf(iso);
          if(i>-1) seleccionadas.splice(i,1);
        }else{
          div.classList.add("selected");
          seleccionadas.push(iso);
        }
        calcular();
      }
   }
   days.appendChild(div);
 }
 return cont;
}

months.appendChild(crearMes(2026,5,"Junio 2026"));
months.appendChild(crearMes(2026,6,"Julio 2026"));
months.appendChild(crearMes(2026,7,"Agosto 2026"));

function calcular(){
 let s=seleccionadas.length;
 let semanas=Math.floor(s/5);
 let sobr=s%5;
 let total=0;

 if(semanas>0){
   total+=160000;
   if(semanas>1) total+=(semanas-1)*140000;
 }
 total+=sobr*35000;

 sesiones.textContent=s;
 totalSpan=document.getElementById("total");
 totalSpan.textContent=total.toLocaleString("es-CO");
 listaFechas.innerHTML=seleccionadas.sort().join("<br>");
 return total;
}

async function reservar(){
 const total=calcular();

 const datos={
 estudiante:estudiante.value,
 edad:edad.value,
 colegio:colegio.value,
 acudiente:acudiente.value,
 cedula:cedula.value,
 telefono:telefono.value,
 email:email.value,
 direccion:direccion.value,
 formaPago:formaPago.value,
 autorizacionFotos:autorizacion.value,
 observaciones:observaciones.value,
 fechas:seleccionadas.join(", "),
 fechasJson:seleccionadas,
 sesiones:seleccionadas.length,
 total:total
 };

 try{
   await fetch(URL_SCRIPT,{
     method:"POST",
     body:JSON.stringify(datos)
   });
   alert("Reserva enviada correctamente");
 }catch(e){

   console.log(e);

   alert("ERROR: " + e);

}
}
</script>
</body>
</html>
